# Frontend Environment Variables for Local Development

### Application Configuration
NODE_ENV=development
REACT_APP_SERVER=http://localhost:8000/
VITE_NODE_ENV=development
VITE_API_SERVER=http://localhost:8000/
###

# Backend Environment Variables for Local Development

### Application Configuration
# NODE_ENV is defined by nodemon in backend
CLIENT               = http://localhost:5173
FRONTEND_URL         = http://localhost:5173/
BACKEND_PORT         = 8000
BACKUP_DIR           = ../backups
###

### Redis Configuration
REDIS_HOST           = redis
REDIS_PORT           = 6379
REDIS_URL            = redis://localhost:6379
REDIS_CACHE_URL      = redis://localhost:6379/0
REDIS_JOB_URL        = redis://localhost:6379/1
###

### MongoDB Configuration
MONGODB_URI          = mongodb://admin:admin123@mongodb:27017/trackmydegree?authSource=admin
###

### SMTP Configuration
# Note: For local development, SMTP is configured with Ethereal Email
###

### JWT & Session Configuration
JWT_SECRET           = very-long-secret-key
JWT_ACCESS_EXPIRY    = 1h
JWT_REFRESH_EXPIRY   = 7d
JWT_ORG_ID           = localhost
SESSION_ALGO         = aes-256-gcm
COOKIE_DOMAIN        = localhost
###

### Sentry Configuration
# For local development, Sentry is not necessary
###

# MongoDB Environment Variables for Local Development
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123
MONGODB_DATABASE=trackmydegree